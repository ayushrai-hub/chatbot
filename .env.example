# Optional: absolute API origin (no trailing slash).
# For local dev, leave this UNSET so Create React App proxies /user → http://localhost:5050
# and you avoid browser CORS issues.
#
# REACT_APP_API_URL=https://your-api.example.com

# Backend (server/) port — default 5050
# PORT=5050

# SQLite database file for the API (server/). Default: server/data/appointments.db
# Use :memory: only for experiments (data is lost when the process exits).
# SQLITE_PATH=./data/appointments.db
